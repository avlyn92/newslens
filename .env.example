# NewsLens Environment Variables
# Copy this file to .env and fill in your keys.
# Keys are stored in localStorage (browser only) — this file is for local development reference.

# The Guardian Open Platform — free at https://open-platform.theguardian.com/access/
VITE_GUARDIAN_API_KEY=your-guardian-key-here

# OpenAI — get yours at https://platform.openai.com/api-keys
# Uses gpt-4o-mini. Typical cost: ~$0.001 per chat message
VITE_OPENAI_API_KEY=sk-your-openai-key-here
